#!/usr/bin/env bash
# =============================================================================
#  erkNVIDIA - NVIDIA Driver Installer for Debian-based Linux Distributions
#  Version: 1.0.0
#  License: MIT
#  Author:  erk
# =============================================================================
#  This script automatically installs NVIDIA proprietary drivers on
#  Debian, Ubuntu, Linux Mint, Pop!_OS, Kali Linux and derivatives.
#
#  Features:
#    - Distribution & version auto-detection
#    - GPU model detection
#    - Multiple driver selection (latest, open-kernel, legacy)
#    - Automatic non-free repository configuration
#    - Nouveau blacklisting
#    - DKMS setup
#    - Secure Boot support (MOK enrollment)
#    - CUDA toolkit integration
#    - Optimus (hybrid graphics) support
#    - Safe rollback / driver removal
# =============================================================================

set -euo pipefail
IFS=$'\n\t'

# ---- Color Definitions ----------------------------------------------------
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly NC='\033[0m' # No Color

# ---- Script Metadata ------------------------------------------------------
readonly SCRIPT_NAME="erkNVIDIA"
readonly SCRIPT_VERSION="1.0.0"

# ---- Global Variables -----------------------------------------------------
DISTRO=""
DISTRO_VERSION=""
DISTRO_ID=""
DISTRO_CODENAME=""
ARCH=""
GPU_NAME=""
GPU_ARCH=""
DRIVER_VERSION=""
SELECTED_DRIVER=""
SECURE_BOOT_STATUS=""
INSTALL_CUDA=false
INSTALL_OPENCL=false
DRY_RUN=false
LOG_FILE="/tmp/${SCRIPT_NAME}.log"

# =============================================================================
#  UTILITY FUNCTIONS
# =============================================================================

log() {
    local level="$1"
    shift
    local msg="$*"
    echo -e "${level}${msg}${NC}"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] ${msg}" >>"$LOG_FILE"
}

info()  { log "$BLUE" "[*] $*"; }
ok()    { log "$GREEN" "[+] $*"; }
warn()  { log "$YELLOW" "[!] $*"; }
error() { log "$RED" "[-] $*"; }

die() {
    error "$*"
    exit 1
}

confirm() {
    local prompt="$1"
    local default="${2:-n}"
    local yn

    if [[ "$default" == "y" ]]; then
        prompt="$prompt [Y/n] "
    else
        prompt="$prompt [y/N] "
    fi

    read -r -p "$prompt" yn
    yn="${yn:-$default}"

    [[ "$yn" =~ ^[YyOoEe] ]]
}

command_exists() {
    command -v "$1" &>/dev/null
}

run_with_progress() {
    local desc="$1"
    shift
    info "$desc..."
    if $DRY_RUN; then
        warn "DRY-RUN: skipping execution"
        return 0
    fi
    if "$@" >>"$LOG_FILE" 2>&1; then
        ok "$desc -> done"
    else
        error "$desc -> FAILED (check $LOG_FILE)"
        return 1
    fi
}

cleanup() {
    info "Cleaning up temporary files..."
    rm -f /tmp/nvidia-*.sh 2>/dev/null || true
}

trap cleanup EXIT

# =============================================================================
#  REQUIREMENT CHECKS
# =============================================================================

check_root() {
    if [[ $EUID -ne 0 ]]; then
        die "This script must be run as root. Use: sudo ./${SCRIPT_NAME}"
    fi
}

check_dependencies() {
    local missing=()

    for cmd in lspci awk grep sed cat lsb_release uname; do
        if ! command_exists "$cmd"; then
            missing+=("$cmd")
        fi
    done

    if [[ ${#missing[@]} -gt 0 ]]; then
        info "Installing missing dependencies: ${missing[*]}..."
        apt-get install -y -qq "${missing[@]}" 2>/dev/null || {
            die "Missing dependencies: ${missing[*]}. Please install them first."
        }
    fi
}

# =============================================================================
#  SYSTEM DETECTION
# =============================================================================

detect_distro() {
    if [[ -f /etc/os-release ]]; then
        source /etc/os-release
        DISTRO="$ID"
        DISTRO_ID="$ID"
        DISTRO_VERSION="$VERSION_ID"
        DISTRO_CODENAME="${VERSION_CODENAME:-${UBUNTU_CODENAME:-}}"
    elif command_exists lsb_release; then
        DISTRO="$(lsb_release -is | tr '[:upper:]' '[:lower:]')"
        DISTRO_VERSION="$(lsb_release -rs)"
        DISTRO_CODENAME="$(lsb_release -cs)"
    else
        die "Cannot detect distribution. /etc/os-release not found."
    fi

    ARCH="$(dpkg --print-architecture 2>/dev/null || uname -m)"

    info "Distribution: $DISTRO $DISTRO_VERSION ($DISTRO_CODENAME)"
    info "Architecture: $ARCH"
}

validate_distro() {
    local supported=false

    case "$DISTRO" in
        debian|ubuntu|linuxmint|pop|elementary|zorin|kali|mx|sparkylinux|devuan)
            supported=true
            ;;
        neon|kde-neon)
            DISTRO="ubuntu"
            DISTRO_CODENAME="$(lsb_release -cs 2>/dev/null || echo 'focal')"
            supported=true
            ;;
        *)
            if confirm "Unsupported distro '$DISTRO'. Continue anyway?"; then
                supported=true
            fi
            ;;
    esac

    $supported || die "Unsupported distribution: $DISTRO"
}

detect_gpu() {
    info "Detecting NVIDIA GPU..."

    if ! lspci 2>/dev/null | grep -i nvidia >/dev/null; then
        die "No NVIDIA GPU detected. This system may not need NVIDIA drivers."
    fi

    GPU_NAME="$(lspci 2>/dev/null | grep -i nvidia | head -1 | sed 's/.*: //')"
    GPU_ARCH="$(lspci -vnn 2>/dev/null | grep -i nvidia | grep -oP '\[10DE:\K[0-9A-F]{4}' | head -1 || echo 'unknown')"

    info "Detected GPU: $GPU_NAME"

    if command_exists nvidia-smi; then
        info "Existing driver detected: $(nvidia-smi --query-gpu=driver_version --format=csv,noheader 2>/dev/null || echo 'unknown')"
    fi
}

get_nvidia_gpu_gen() {
    local device_id="$1"
    # GPU generations by architecture
    # Turing, Ampere, Ada Lovelace, Blackwell -> newer (supports open kernel module)
    # Pascal, Maxwell, Kepler -> legacy

    local gpu_info
    gpu_info="$(lspci -vnn 2>/dev/null | grep -i nvidia | head -1)"
    
    if echo "$gpu_info" | grep -qiE '(RTX [34][0-9]{2}|RTX 50|RTX 40|RTX 30|RTX 20|GTX 16|TITAN V|TITAN RTX)'; then
        echo "modern"
    elif echo "$gpu_info" | grep -qiE '(GTX 10|GTX 9|GTX 7|GTX 6|TITAN X)'; then
        echo "pascal_maxwell"  # Legacy but still supported
    elif echo "$gpu_info" | grep -qiE '(GTX 5|GT 4|GT 2|Quadro [FKV])'; then
        echo "legacy"
    else
        # Try to identify by PCI ID ranges
        case "$device_id" in
            [0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F])
                # Modern GPUs (Turing+)
                if [[ "0x${device_id}" -gt "0x1E00" ]]; then
                    echo "modern"
                else
                    echo "unknown"
                fi
                ;;
            *)
                echo "unknown"
                ;;
        esac
    fi
}

detect_secure_boot() {
    if command_exists mokutil; then
        SECURE_BOOT_STATUS="$(mokutil --sb-state 2>/dev/null || true)"
    elif [[ -d /sys/firmware/efi ]] && [[ -f /sys/firmware/efi/efivars/SecureBoot-* ]]; then
        local sb
        sb="$(cat /sys/firmware/efi/efivars/SecureBoot-* 2>/dev/null | od -An -t u1 | head -1 | awk '{print $2}')"
        if [[ "$sb" == "1" ]]; then
            SECURE_BOOT_STATUS="Secure Boot: enabled"
        else
            SECURE_BOOT_STATUS="Secure Boot: disabled"
        fi
    else
        SECURE_BOOT_STATUS="Secure Boot: N/A (BIOS/Legacy mode)"
    fi
    info "$SECURE_BOOT_STATUS"
}

# =============================================================================
#  REPOSITORY MANAGEMENT
# =============================================================================

setup_repositories() {
    info "Configuring repositories for NVIDIA drivers..."

    case "$DISTRO" in
        debian)
            setup_debian_repos
            ;;
        ubuntu|linuxmint|pop|elementary|zorin|neon)
            setup_ubuntu_repos
            ;;
        kali)
            setup_kali_repos
            ;;
        *)
            if confirm "Automatic repo setup not supported for $DISTRO. Manually configured?"; then
                info "Continuing with existing repo configuration..."
            else
                die "Please configure NVIDIA repositories manually and re-run."
            fi
            ;;
    esac
}

setup_debian_repos() {
    local sources_file="/etc/apt/sources.list"
    local codename="$DISTRO_CODENAME"

    # Handle bookworm, trixie, sid, etc.
    if [[ ! -f "$sources_file" ]]; then
        sources_file="/etc/apt/sources.list.d/debian.sources"
    fi

    # Add non-free and non-free-firmware if missing
    local added=false

    if [[ "$codename" == "bookworm" ]]; then
        if ! grep -qr "non-free-firmware" /etc/apt/sources.list /etc/apt/sources.list.d/ 2>/dev/null; then
            info "Adding non-free-firmware component for Bookworm..."
            if [[ -f /etc/apt/sources.list ]]; then
                sed -i 's/main/main non-free non-free-firmware/g' /etc/apt/sources.list
            elif [[ -f /etc/apt/sources.list.d/debian.sources ]]; then
                # Handle deb822 format
                sed -i 's/Components: main/Components: main non-free non-free-firmware/g' /etc/apt/sources.list.d/debian.sources
            fi
            added=true
        fi
    else
        if ! grep -qr "non-free" /etc/apt/sources.list /etc/apt/sources.list.d/ 2>/dev/null; then
            info "Adding non-free component..."
            if [[ -f /etc/apt/sources.list ]]; then
                sed -i 's/main/main non-free/g' /etc/apt/sources.list
            fi
            added=true
        fi
    fi

    # For Debian, we use the nvidia-detect package to find the right driver
    if $added; then
        info "Updating package lists..."
        apt-get update -qq 2>/dev/null || warn "apt update had issues (check $LOG_FILE)"
        ok "Repository updated with non-free components"
    fi

    # Install nvidia-detect if available
    if apt-cache show nvidia-detect &>/dev/null; then
        info "nvidia-detect is available for driver auto-detection"
    fi
}

setup_ubuntu_repos() {
    # Ubuntu uses the Proprietary GPU Drivers PPA
    if ! grep -qr "graphics-drivers" /etc/apt/sources.list /etc/apt/sources.list.d/ 2>/dev/null; then
        info "Adding Ubuntu Graphics Drivers PPA..."
        if command_exists add-apt-repository; then
            add-apt-repository -y ppa:graphics-drivers/ppa >>"$LOG_FILE" 2>&1 || {
                warn "PPA add failed; trying alternative method..."
                echo "deb http://ppa.launchpad.net/graphics-drivers/ppa/ubuntu ${DISTRO_CODENAME} main" > /etc/apt/sources.list.d/nvidia-ppa.list
                apt-key adv --keyserver keyserver.ubuntu.com --recv-keys E6D4736255751E5D 2>/dev/null || true
            }
        else
            apt-get install -y -qq software-properties-common >>"$LOG_FILE" 2>&1
            add-apt-repository -y ppa:graphics-drivers/ppa >>"$LOG_FILE" 2>&1 || {
                echo "deb http://ppa.launchpad.net/graphics-drivers/ppa/ubuntu ${DISTRO_CODENAME} main" > /etc/apt/sources.list.d/nvidia-ppa.list
            }
        fi
        ok "Graphics Drivers PPA added"
    else
        info "Graphics Drivers PPA already configured"
    fi

    info "Updating package lists..."
    apt-get update -qq 2>/dev/null || warn "apt update had issues (check $LOG_FILE)"
}

setup_kali_repos() {
    # Kali is Debian-based; non-free is usually already configured
    if ! grep -qr "non-free" /etc/apt/sources.list /etc/apt/sources.list.d/ 2>/dev/null; then
        warn "Kali may need non-free repositories. Attempting to configure..."
        # Kali typically uses a single sources.list
        if grep -q "kali-rolling" /etc/apt/sources.list 2>/dev/null; then
            sed -i 's/main/main non-free contrib/g' /etc/apt/sources.list
        fi
        apt-get update -qq 2>/dev/null || true
    fi
}

# =============================================================================
#  DRIVER DETECTION & SELECTION
# =============================================================================

find_available_drivers() {
    info "Scanning available NVIDIA drivers..."

    local drivers=()

    # Try different driver search methods based on distro
    if [[ "$DISTRO" == "debian" ]]; then
        # Debian uses nvidia-driver (with version suffixes)
        mapfile -t drivers < <(apt-cache search '^nvidia-driver$' 2>/dev/null || true)

        # Check for specific versions
        for ver in 570 565 560 555 550 545 540 535 530 525 520 515 510 505 495 470 460 450 440 435 430 425 418 415 410 405 396 390 384 381 378 375 367 361 358 355 352 349 346 343 340 337 334 331 325 319 313 310 304 295 285 275 270 266 260 256 195 190 185 180 177 173 169 160 96 71; do
            if apt-cache show "nvidia-driver-${ver}" &>/dev/null 2>/dev/null; then
                drivers+=("nvidia-driver-${ver}")
            fi
        done
    else
        # Ubuntu/Pop/Mint use nvidia-driver-XXX
        mapfile -t drivers < <(apt-cache search '^nvidia-driver-[0-9]' 2>/dev/null | sort -V || true)
    fi

    if [[ ${#drivers[@]} -eq 0 ]]; then
        # Fallback: generic nvidia-driver
        if apt-cache show nvidia-driver &>/dev/null 2>/dev/null; then
            drivers=("nvidia-driver")
        fi
    fi

    printf '%s\n' "${drivers[@]}"
}

detect_best_driver() {
    info "Determining best driver for your GPU..."

    local gpu_gen
    gpu_gen="$(get_nvidia_gpu_gen "$GPU_ARCH")"

    # Available drivers from repos
    local available
    available="$(find_available_drivers)"

    if [[ -z "$available" ]]; then
        die "No NVIDIA drivers found in repositories. Check your repository configuration."
    fi

    echo "$available"

    case "$gpu_gen" in
        modern)
            ok "GPU is modern (Turing/Ampere/Ada/Blackwell) - latest driver recommended"
            ;;
        pascal_maxwell)
            ok "GPU is Pascal/Maxwell generation - driver 470+ recommended"
            ;;
        legacy)
            warn "GPU may need legacy driver series"
            ;;
        *)
            warn "GPU generation unknown; will try latest compatible driver"
            ;;
    esac
}

select_driver_interactive() {
    echo ""
    echo -e "${CYAN}============================================${NC}"
    echo -e "${CYAN}  NVIDIA Driver Selection${NC}"
    echo -e "${CYAN}============================================${NC}"
    echo ""

    local options=()
    options+=("1) Latest stable driver (recommended)")
    options+=("2) Open kernel module driver (Turing+ GPUs only)")
    options+=("3) Legacy driver series")
    options+=("4) CUDA toolkit only (no driver)")
    options+=("5) Remove NVIDIA drivers completely")

    for opt in "${options[@]}"; do
        echo "  $opt"
    done
    echo ""

    local choice
    read -r -p "Select option [1-5]: " choice

    case "$choice" in
        1) SELECTED_DRIVER="latest" ;;
        2) SELECTED_DRIVER="open" ;;
        3) SELECTED_DRIVER="legacy" ;;
        4) SELECTED_DRIVER="cuda-only" ;;
        5) SELECTED_DRIVER="remove" ;;
        *) SELECTED_DRIVER="latest" ;;
    esac

    if confirm "Install CUDA toolkit as well?" "n"; then
        INSTALL_CUDA=true
    fi

    if confirm "Install OpenCL support?" "n"; then
        INSTALL_OPENCL=true
    fi
}

select_driver_auto() {
    local gpu_gen
    gpu_gen="$(get_nvidia_gpu_gen "$GPU_ARCH")"

    case "$gpu_gen" in
        modern)
            SELECTED_DRIVER="latest"
            ;;
        pascal_maxwell)
            SELECTED_DRIVER="latest"
            ;;
        legacy)
            if confirm "Legacy GPU detected. Use legacy driver series?" "y"; then
                SELECTED_DRIVER="legacy"
            else
                SELECTED_DRIVER="latest"
            fi
            ;;
        *)
            SELECTED_DRIVER="latest"
            ;;
    esac

    info "Auto-selected: $SELECTED_DRIVER driver"
}

# =============================================================================
#  NOUVEAU DISABLE
# =============================================================================

disable_nouveau() {
    info "Checking if nouveau needs to be disabled..."

    if lsmod | grep -q nouveau; then
        warn "Nouveau driver is loaded. It will be blacklisted."

        # Blacklist nouveau
        local conf_file="/etc/modprobe.d/nvidia-blacklist-nouveau.conf"
        cat >"$conf_file" <<'BLACKLIST'
blacklist nouveau
blacklist lbm-nouveau
options nouveau modeset=0
alias nouveau off
alias lbm-nouveau off
BLACKLIST

        ok "Nouveau blacklisted"

        # Update initramfs if we're not in a dry run
        if ! $DRY_RUN; then
            info "Updating initramfs..."
            if command_exists update-initramfs; then
                update-initramfs -u >>"$LOG_FILE" 2>&1 || true
            fi
        fi
    else
        ok "Nouveau is not loaded"
    fi
}

# =============================================================================
#  DRIVER INSTALLATION
# =============================================================================

install_latest_driver() {
    info "Installing latest NVIDIA driver..."

    local packages=()

    case "$DISTRO" in
        debian)
            # Debian has metapackage nvidia-driver (with firmware)
            packages+=("nvidia-driver" "firmware-nvidia-gsp")

            if apt-cache show nvidia-driver-full &>/dev/null 2>/dev/null; then
                packages+=("nvidia-driver-full")
            fi
            ;;
        ubuntu|linuxmint|pop|elementary|zorin|neon)
            # Find the latest version available
            local latest
            latest="$(apt-cache search '^nvidia-driver-[0-9]' 2>/dev/null | sort -V | tail -1 | awk '{print $1}')"
            packages+=("${latest:-nvidia-driver-570}")

            # Add recommended packages
            packages+=("nvidia-utils-${latest#nvidia-driver-}" 2>/dev/null || true)
            packages+=("libnvidia-common-${latest#nvidia-driver-}" 2>/dev/null || true)
            ;;
        kali)
            packages+=("nvidia-driver" "nvidia-kernel-dkms")
            ;;
        *)
            packages+=("nvidia-driver")
            ;;
    esac

    # Common packages
    packages+=("nvidia-kernel-dkms" "nvidia-smi")

    # Remove duplicates
    mapfile -t packages < <(printf '%s\n' "${packages[@]}" | sort -u)

    run_with_progress "Installing NVIDIA driver packages" apt-get install -y "${packages[@]}"

    if $INSTALL_CUDA; then
        install_cuda
    fi

    if $INSTALL_OPENCL; then
        install_opencl
    fi
}

install_open_driver() {
    info "Installing NVIDIA open kernel module driver..."

    local packages=()

    case "$DISTRO" in
        debian)
            packages+=("nvidia-tesla-570-driver" "nvidia-tesla-570-kernel-open-dkms")
            ;;
        ubuntu|linuxmint|pop)
            packages+=("nvidia-kernel-open-common" "nvidia-kernel-open-dkms" "nvidia-driver-570")
            ;;
        *)
            warn "Open kernel module not well-supported on $DISTRO; falling back to proprietary"
            install_latest_driver
            return
            ;;
    esac

    packages+=("nvidia-smi")

    run_with_progress "Installing NVIDIA open kernel module" apt-get install -y "${packages[@]}"
}

install_legacy_driver() {
    info "Installing legacy NVIDIA driver..."

    local packages=()
    local gpu_name_upper
    gpu_name_upper="$(echo "$GPU_NAME" | tr '[:lower:]' '[:upper:]')"

    # Determine which legacy version to use
    if echo "$gpu_name_upper" | grep -qE '(GTX 7|GTX 8|GTX 9|QUADRO M)'; then
        # Maxwell/Maxwell2 -> driver 470
        packages+=("nvidia-driver-470")
    elif echo "$gpu_name_upper" | grep -qE '(GTX 6|GT 6|GT 7|QUADRO K)'; then
        # Kepler -> driver 470
        packages+=("nvidia-driver-470")
    elif echo "$gpu_name_upper" | grep -qE '(GT 2|GT 3|GT 4|GT 5|QUADRO F|QUADRO 6)'; then
        # Fermi/older -> driver 340
        packages+=("nvidia-legacy-340xx-driver")
    else
        # Try 470 as a safe fallback
        warn "GPU model not identified; trying legacy driver 470"
        packages+=("nvidia-driver-470")
    fi

    run_with_progress "Installing legacy NVIDIA driver" apt-get install -y "${packages[@]}"
}

install_cuda() {
    info "Installing CUDA toolkit..."
    local packages=()

    case "$DISTRO" in
        debian)
            # Add CUDA repository
            local cuda_repo="https://developer.download.nvidia.com/compute/cuda/repos/debian${DISTRO_VERSION}/x86_64"
            if ! grep -qr "developer.download.nvidia.com" /etc/apt/sources.list /etc/apt/sources.list.d/ 2>/dev/null; then
                run_with_progress "Adding CUDA repository" bash -c "
                    wget -qO /tmp/cuda-keyring.deb ${cuda_repo}/cuda-keyring_1.1-1_all.deb
                    dpkg -i /tmp/cuda-keyring.deb
                "
            fi
            packages+=("cuda-toolkit")
            ;;
        ubuntu|pop)
            if ! grep -qr "developer.download.nvidia.com" /etc/apt/sources.list /etc/apt/sources.list.d/ 2>/dev/null; then
                run_with_progress "Adding CUDA repository" bash -c "
                    wget -qO /tmp/cuda-keyring.deb https://developer.download.nvidia.com/compute/cuda/repos/ubuntu${DISTRO_VERSION}/x86_64/cuda-keyring_1.1-1_all.deb
                    dpkg -i /tmp/cuda-keyring.deb
                "
            fi
            apt-get update -qq 2>/dev/null || true
            packages+=("cuda-toolkit")
            ;;
        *)
            warn "CUDA auto-install not supported on $DISTRO"
            echo "  Manual: https://developer.nvidia.com/cuda-downloads"
            return
            ;;
    esac

    run_with_progress "Installing CUDA toolkit" apt-get install -y "${packages[@]}"
}

install_opencl() {
    info "Installing NVIDIA OpenCL support..."
    local packages=()

    if apt-cache show nvidia-opencl-icd &>/dev/null 2>/dev/null; then
        packages+=("nvidia-opencl-icd")
    fi

    if [[ ${#packages[@]} -gt 0 ]]; then
        run_with_progress "Installing OpenCL support" apt-get install -y "${packages[@]}"
    else
        warn "OpenCL packages not found in repositories"
    fi
}

remove_nvidia_drivers() {
    warn "This will REMOVE all NVIDIA drivers!"
    if ! confirm "Are you sure?" "n"; then
        info "Aborted."
        return
    fi

    info "Removing NVIDIA packages..."

    # Get all nvidia packages
    local nvidia_pkgs
    nvidia_pkgs="$(dpkg -l 2>/dev/null | grep -i nvidia | awk '{print $2}' | tr '\n' ' ' || true)"

    if [[ -n "$nvidia_pkgs" ]]; then
        run_with_progress "Removing NVIDIA packages" apt-get remove --purge -y $nvidia_pkgs
        run_with_progress "Cleaning up" apt-get autoremove --purge -y
    else
        info "No NVIDIA packages found"
    fi

    # Remove blacklist
    rm -f /etc/modprobe.d/nvidia-blacklist-nouveau.conf

    # Restore nouveau
    info "Nouveau driver restored. A reboot is required."
}

# =============================================================================
#  POST-INSTALLATION
# =============================================================================

handle_secure_boot() {
    if ! command_exists mokutil; then
        info "mokutil not installed, skipping Secure Boot setup"
        return
    fi

    local sb_state
    sb_state="$(mokutil --sb-state 2>/dev/null || true)"

    if echo "$sb_state" | grep -qi "enabled"; then
        warn "Secure Boot is enabled. You may need to sign the NVIDIA kernel module."
        echo ""
        echo "  Option 1: Disable Secure Boot in BIOS"
        echo "  Option 2: Sign the module with MOK (Machine Owner Key)"
        echo ""
        echo "  To sign manually after reboot:"
        echo "    sudo mokutil --import /var/lib/dkms/nvidia/*/mok.pub"
        echo ""

        if confirm "Would you like to import the MOK key now?" "n"; then
            local mok_pub
            mok_pub="$(find /var/lib/dkms/ -name 'mok.pub' 2>/dev/null | head -1)"
            if [[ -f "$mok_pub" ]]; then
                run_with_progress "Importing MOK key" mokutil --import "$mok_pub"
                ok "MOK key imported. You'll be prompted to set a password and confirm on next reboot."
            else
                warn "MOK public key not found at $mok_pub"
                warn "After reboot, run: sudo mokutil --import /var/lib/dkms/nvidia/*/mok.pub"
            fi
        fi
    fi
}

configure_drm() {
    # Enable NVIDIA DRM (Direct Rendering Manager) for Wayland support
    local modprobe_file="/etc/modprobe.d/nvidia-drm.conf"

    if [[ ! -f "$modprobe_file" ]]; then
        cat >"$modprobe_file" <<'DRM'
# Enable NVIDIA DRM (required for Wayland support)
options nvidia-drm modeset=1
DRM
        ok "NVIDIA DRM modeset enabled for Wayland support"
    fi
}

configure_persistence() {
    if ! $DRY_RUN; then
        # Enable persistence daemon for better power management
        if command_exists nvidia-persistenced; then
            systemctl enable nvidia-persistenced 2>/dev/null || true
            systemctl start nvidia-persistenced 2>/dev/null || true
            ok "NVIDIA Persistence Daemon enabled"
        fi
    fi
}

verify_installation() {
    echo ""
    echo -e "${CYAN}============================================${NC}"
    echo -e "${CYAN}  Installation Verification${NC}"
    echo -e "${CYAN}============================================${NC}"
    echo ""

    local nvidia_ok=true

    # Check if nvidia-smi works
    if command_exists nvidia-smi; then
        echo ""
        echo -e "${GREEN}nvidia-smi output:${NC}"
        nvidia-smi 2>/dev/null || {
            warn "nvidia-smi failed; driver may not be loaded"
            nvidia_ok=false
        }
    else
        warn "nvidia-smi not found"
        nvidia_ok=false
    fi

    # Check kernel module
    if lsmod | grep -q nvidia; then
        ok "NVIDIA kernel module is loaded"
    else
        warn "NVIDIA kernel module NOT loaded (reboot may be needed)"
        nvidia_ok=false
    fi

    # Check DKMS status
    if command_exists dkms; then
        echo ""
        echo -e "${BLUE}DKMS Status:${NC}"
        dkms status 2>/dev/null | grep -i nvidia || echo "  No NVIDIA modules in DKMS"
    fi

    # Check CUDA
    if $INSTALL_CUDA; then
        if command_exists nvcc; then
            ok "CUDA $(nvcc --version 2>/dev/null | grep release | awk '{print $6}' | tr -d ',') installed"
        else
            warn "CUDA installation may need PATH configuration: export PATH=/usr/local/cuda/bin:\$PATH"
        fi
    fi

    echo ""

    if $nvidia_ok; then
        echo -e "${GREEN}============================================${NC}"
        echo -e "${GREEN}  NVIDIA driver installation SUCCESSFUL!${NC}"
        echo -e "${GREEN}============================================${NC}"
    else
        echo -e "${YELLOW}============================================${NC}"
        echo -e "${YELLOW}  Installation completed with warnings${NC}"
        echo -e "${YELLOW}  A reboot may be required to load the driver.${NC}"
        echo -e "${YELLOW}============================================${NC}"
    fi
}

print_post_instructions() {
    echo ""
    echo -e "${CYAN}============================================${NC}"
    echo -e "${CYAN}  Post-Installation Notes${NC}"
    echo -e "${CYAN}============================================${NC}"
    echo ""
    echo " 1. REBOOT your system to load the NVIDIA driver:"
    echo "    sudo reboot"
    echo ""
    echo " 2. After reboot, verify the driver:"
    echo "    nvidia-smi"
    echo ""
    echo " 3. Configure PRIME (for laptops with Optimus):"
    echo "    sudo prime-select nvidia"
    echo "    sudo prime-select query"
    echo ""
    echo " 4. For Wayland support, ensure DRM modeset is enabled:"
    echo "    cat /etc/modprobe.d/nvidia-drm.conf"
    echo ""
    echo " 5. To update drivers in the future:"
    echo "    sudo apt update && sudo apt upgrade"
    echo ""
    echo " 6. Log file: $LOG_FILE"
    echo ""

    if ! command_exists nvidia-smi; then
        echo -e " ${YELLOW}NOTE: Driver not yet active. This is normal before reboot.${NC}"
    fi
}

