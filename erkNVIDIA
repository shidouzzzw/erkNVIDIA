print_banner() {
    echo ""
    echo -e "${CYAN}  ______  _____  _   _  ____  _   _ _____ _____ _____  ___  ${NC}"
    echo -e "${CYAN} |  ____|  __ \| \ | |/ __ \| \ | |_   _|_   _|  __ \|__ \ ${NC}"
    echo -e "${CYAN} | |__  | |__) |  \| | |  | |  \| | | |   | | | |__) |  ) |${NC}"
    echo -e "${CYAN} |  __| |  _  /| .   | |  | | .   | | |   | | |  _  /  / / ${NC}"
    echo -e "${CYAN} | |____| | \ \| |\  | |__| | |\  |_| |_ _| |_| | \ \ / /_ ${NC}"
    echo -e "${CYAN} |______|_|  \_\_| \_|\____/|_| \_|_____|_____|_|  \_\____|${NC}"
    echo ""
    echo -e "${GREEN}  NVIDIA Driver Installer for Debian-based Linux${NC}"
    echo -e "${GREEN}  Version ${SCRIPT_VERSION}${NC}"
    echo ""
    echo -e "${YELLOW}  WARNING: This script modifies system configuration.${NC}"
    echo -e "${YELLOW}  Use at your own risk. Backup your data first.${NC}"
    echo ""
}

usage() {
    echo "Usage: sudo ./${SCRIPT_NAME} [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  -h, --help       Show this help message"
    echo "  -y, --yes        Non-interactive mode (auto-select best driver)"
    echo "  -d, --dry-run    Simulate without making changes"
    echo "  --cuda           Install CUDA toolkit alongside driver"
    echo "  --opencl         Install OpenCL support"
    echo "  --open           Use open kernel module (Turing+ GPUs)"
    echo "  --legacy         Force legacy driver selection"
    echo "  --remove         Remove all NVIDIA drivers"
    echo "  --driver VER     Specify driver version (e.g. 570)"
    echo ""
    echo "Examples:"
    echo "  sudo ./${SCRIPT_NAME}"
    echo "  sudo ./${SCRIPT_NAME} -y --cuda"
    echo "  sudo ./${SCRIPT_NAME} --remove"
    echo "  sudo ./${SCRIPT_NAME} --open"
    echo ""
}

parse_args() {
    local non_interactive=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                usage
                exit 0
                ;;
            -y|--yes)
                non_interactive=true
                ;;
            -d|--dry-run)
                DRY_RUN=true
                warn "DRY RUN MODE - No changes will be made"
                ;;
            --cuda)
                INSTALL_CUDA=true
                ;;
            --opencl)
                INSTALL_OPENCL=true
                ;;
            --open)
                SELECTED_DRIVER="open"
                ;;
            --legacy)
                SELECTED_DRIVER="legacy"
                ;;
            --remove)
                SELECTED_DRIVER="remove"
                ;;
            --driver)
                shift
                SELECTED_DRIVER="$1"
                ;;
            *)
                warn "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
        shift
    done

    echo "$non_interactive"
}

main() {
    local non_interactive
    non_interactive="$(parse_args "$@")"

    print_banner

    # ---- Pre-flight checks ----
    check_root
    check_dependencies

    # ---- System detection ----
    detect_distro
    validate_distro
    detect_gpu
    detect_secure_boot

    # ---- Driver selection ----
    if [[ -z "$SELECTED_DRIVER" ]]; then
        if $non_interactive; then
            select_driver_auto
        else
            echo ""
            detect_best_driver | while IFS= read -r line; do
                [[ -n "$line" ]] && info "  Available: $line"
            done
            select_driver_interactive
        fi
    fi

    # ---- Action based on selection ----
    case "$SELECTED_DRIVER" in
        remove)
            remove_nvidia_drivers
            info "Done. Reboot to complete removal."
            exit 0
            ;;
        cuda-only)
            setup_repositories
            install_cuda
            ok "CUDA toolkit installed without driver"
            ;;
        *)
            setup_repositories
            disable_nouveau

            case "$SELECTED_DRIVER" in
                open)     install_open_driver ;;
                legacy)   install_legacy_driver ;;
                latest|*) install_latest_driver ;;
            esac

            config_drm
            handle_secure_boot
            configure_persistence
            ;;
    esac

    # ---- Verification ----
    echo ""
    info "Verifying installation..."
    verify_installation
    print_post_instructions

    ok "Script completed. Check $LOG_FILE for details."

    if ! $DRY_RUN; then
        echo ""
        if confirm "Reboot now to load NVIDIA drivers?" "n"; then
            info "Rebooting..."
            reboot
        fi
    fi
}

main "$@"
